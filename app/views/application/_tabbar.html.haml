%div.d-flex.flex-row.justify-content-between{class: "#{bar_class}"}
    %div.d-flex.flex-row.flex-flow-wrap
        - tabs.each do |tab|
            - unless tab[:admin_only] && !admin?
                = link_to tab[:path], class: "nav-link h-100 d-flex align-items-center border-0 border-bottom-100 #{'active' if active_path == tab[:path]}" do
                    = tab[:title]
    %div
        = yield if defined?(do_yield) && do_yield|| false
