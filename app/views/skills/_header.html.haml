%div.d-flex.flex-column.bg-white{"data-controller": "skillset-selected"}
  = form_with(url: skills_path, method: :get, data: { turbo_frame: 'skills' }) do |form|
    %div.d-flex.flex-row.mt-2
      = form.text_field :title, class: "form-control skills-search-field rounded-end-0", placeholder: "#{ti('filter.search', target: Skill.model_name.human)}", oninput: "this.form.requestSubmit()", include_blank: true
      %div.border.d-flex.rounded-end.bg-white
        %img.pointer.p-2{src: "/assets/search.svg"}

    %span.d-flex.flex-row.mt-3.flex-wrap.gap-2
      %div.btn-group.me-3
        = radio_button_tag :defaultSet, "", check_entry_validity?(""), class: "btn-check", id: "default_set_all", tabindex: "-1", onchange: "this.form.requestSubmit();"
        %label.btn.btn-outline-primary{for: "default_set_all", tabindex: "0", onkeydown: "['Enter', 'Space'].includes(event.code) && this.click()"}
          = ti('filter.all')

        = radio_button_tag :defaultSet, "new", check_entry_validity?("new"), class: "btn-check", id: "default_set_new", tabindex: "-1", onchange: "this.form.requestSubmit();"
        %label.btn.btn-outline-primary{for: "default_set_new", tabindex: "0", onkeydown: "['Enter', 'Space'].includes(event.code) && this.click()"}
          = ti('filter.new')

        = radio_button_tag :defaultSet, "true", check_entry_validity?("true"), class: "btn-check", id: "default_set_true", tabindex: "-1" , onchange: "this.form.requestSubmit();"
        %label.btn.btn-outline-primary{for: "default_set_true", tabindex: "0", onkeydown: "['Enter', 'Space'].includes(event.code) && this.click()"}
          = ti('filter.default')
      %span.d-flex.align-items-center.flex-wrap
        %span.text-gray.me-1
          = "#{Category.model_name.human}:"
        = form.collection_select :category, Category.all_parents.order(:title), :id, :title, {prompt: true}, class: "form-select fit-content", onchange: 'this.form.requestSubmit();'
      = admin_export_action_link  export_skills_path, "data-turbo-prefetch": false , data: { turbo: false }
      = add_action_link_modal
