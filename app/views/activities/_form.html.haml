= form_with model: ([entry.person, entry]) do |f|
  = render('people/person_relations/form', form: f) do
    - content_for :input do
      = f.label :role
      = f.text_area :role, placeholder: "Rolle", class: "form-control w-100", oninput: "this.style.height = 'auto'; this.style.height = this.scrollHeight + 'px';"
      :javascript
        (function() {
          var el = document.getElementById('activity_role');
          if (el) {
            el.style.height = 'auto';
            el.style.height = el.scrollHeight + 'px';
          }
        })();
      = f.label :description
      = f.text_area :description, placeholder: "Beschreibung", class: "form-control w-100", oninput: "this.style.height = 'auto'; this.style.height = this.scrollHeight + 'px';"
      :javascript
        (function() {
          var el = document.getElementById('activity_description');
          if (el) {
            el.style.height = 'auto';
            el.style.height = el.scrollHeight + 'px';
          }
        })();
      .flex-row.mt-1
        = f.label :display_in_cv, class: "form-check-label text-gray me-1"
        = f.checkbox :display_in_cv, class: "form-check-input"