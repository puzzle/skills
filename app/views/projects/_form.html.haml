= form_with model: ([entry.person, entry]) do |f|
  = render('people/person_relations/form', form: f) do
    - content_for :input do
      = f.label :title
      = f.text_field :title, placeholder: "Title", class: "form-control w-100"
      = f.label :description
      = f.text_area :description, placeholder: "Description", class: "form-control w-100", oninput: "this.style.height = 'auto'; this.style.height = this.scrollHeight + 'px';"
      :javascript
        (function() {
          var el = document.getElementById('project_description');
          if (el) {
            el.style.height = 'auto';
            el.style.height = el.scrollHeight + 'px';
          }
        })();
      = f.label :technology
      = f.text_area :technology, placeholder: "Description", class: "form-control w-100", oninput: "this.style.height = 'auto'; this.style.height = this.scrollHeight + 'px';"
      :javascript
        (function() {
          var el = document.getElementById('project_technology');
          if (el) {
            el.style.height = 'auto';
            el.style.height = el.scrollHeight + 'px';
          }
        })();
      = f.label :role
      = f.text_area :role, placeholder: "Description", class: "form-control w-100", oninput: "this.style.height = 'auto'; this.style.height = this.scrollHeight + 'px';"
      :javascript
        (function() {
          var el = document.getElementById('project_role');
          if (el) {
            el.style.height = 'auto';
            el.style.height = el.scrollHeight + 'px';
          }
        })();
      .flex-row.mt-1
        = f.label :display_in_cv, class: "form-check-label text-gray me-1"
        = f.checkbox :display_in_cv, class: "form-check-input"