{
  "name": "app",
  "private": true,
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.23",
    "@popperjs/core": "^2.11.8",
    "autoprefixer": "^10.5.2",
    "bootstrap": "^5.3.8",
    "chart.js": "^4.5.1",
    "chartjs-plugin-annotation": "^3.1.0",
    "esbuild": "^0.28.1",
    "esbuild-rails": "^1.0.7",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.19",
    "postcss-cli": "^11.0.1",
    "sass": "^1.101.0",
    "slim-select": "^4.0.7"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:css:dev": "sass ./app/assets/stylesheets/application.scss:./app/assets/builds/application.css --no-source-map --load-path=node_modules",
    "build:css:prod": "sass ./app/assets/stylesheets/application.scss:./app/assets/builds/application.css --no-source-map --load-path=node_modules --style=compressed",
    "build:css:prefix": "postcss ./app/assets/builds/application.css --use=autoprefixer --output=./app/assets/builds/application.css",
    "build:css": "node css-build.mjs",
    "watch:css": "nodemon --watch ./app/assets/stylesheets/ --ext scss --exec \"yarn build:css\""
  },
  "browserslist": [
    "defaults"
  ],
  "engines": {
    "npm": "please-use-yarn",
    "yarn": ">= 4.12.0",
    "node": ">= 24.13.0"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "packageManager": "yarn@4.12.0"
}
